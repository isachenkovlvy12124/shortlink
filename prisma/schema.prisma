generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  createdAt     DateTime  @default(now())
  links         Link[]
}

model Link {
  id          String    @id @default(cuid())
  slug        String    @unique
  originalUrl String
  title       String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  clicks      Click[]
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?
  referer   String?
  ip        String?
  createdAt DateTime @default(now())
}
